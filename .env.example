# Postgres -- used for local dev only (docker-compose's db service). In
# production this is replaced entirely by Supabase's own Postgres instance.
POSTGRES_USER=aihost
POSTGRES_PASSWORD=change-me-dev-password
POSTGRES_DB=aihost

# Backend: database connection. Locally this points at the docker-compose `db`
# service; in production set it to your Supabase project's connection string
# (Project Settings > Database > Connection string > URI, "Transaction" pooler
# mode), with the postgresql+psycopg:// scheme.
DATABASE_URL=postgresql+psycopg://aihost:change-me-dev-password@db:5432/aihost

# Supabase (Auth + Storage). Get these from Project Settings > API once you've
# created a project at https://supabase.com.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Only used for projects still on legacy HS256 JWT signing (and for local
# dev/test tokens). Projects using Supabase's newer asymmetric signing keys
# (ES256) are verified automatically via the JWKS endpoint derived from
# SUPABASE_URL above -- this can be left blank for those.
SUPABASE_JWT_SECRET=your-jwt-secret

CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# DeepSeek (OpenAI-compatible) API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Frontend (Vite, build-time)
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Frontend (Next.js / Vercel)
# Leave NEXT_PUBLIC_API_BASE_URL blank on Vercel when deploying the included
# Python FastAPI function at /api. For local Next dev, point it at FastAPI.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional for local Next rewrites to an already-running backend.
# Do not set this for the all-in-one Vercel deployment unless you want to proxy
# /api/* to an external FastAPI service instead of the included api/index.py.
BACKEND_URL=http://localhost:8000
